# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=documentos_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change_me_in_production

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_BUCKET=documentos-files

# ─── Strapi ──────────────────────────────────────────────────────────────────
STRAPI_PORT=1337
# Generar con: openssl rand -base64 32
JWT_SECRET=change_me_in_production
ADMIN_JWT_SECRET=change_me_in_production
API_TOKEN_SALT=change_me_in_production
TRANSFER_TOKEN_SALT=change_me_in_production
APP_KEYS=key1,key2,key3,key4

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_in_production
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:1337

# ─── Entorno ─────────────────────────────────────────────────────────────────
NODE_ENV=development
